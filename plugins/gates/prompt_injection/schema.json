{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/plugins/nexus.gate.prompt_injection.json",
  "title": "nexus.gate.prompt_injection",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "action":   {"type": "string", "enum": ["block", "warn"], "description": "Block input or just emit a warning on match."},
    "message":  {"type": "string", "description": "Message returned/logged when blocked."},
    "patterns": {
      "description": "Inline patterns; either a YAML list of strings or a single string.",
      "oneOf": [
        {"type": "array", "items": {"type": "string"}},
        {"type": "string"}
      ]
    },
    "patterns_file": {"type": "string", "description": "Path to a file containing one pattern per line."}
  }
}
