{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/plugins/nexus.gate.content_safety.json",
  "title": "nexus.gate.content_safety",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "action":  {"type": "string", "enum": ["block", "redact"], "description": "How to handle matches."},
    "message": {"type": "string", "description": "Message returned/logged on block; supports {checks} placeholder."},
    "check_pii_email":          {"type": "boolean", "description": "Detect email addresses."},
    "check_pii_phone":          {"type": "boolean", "description": "Detect phone numbers."},
    "check_pii_ssn":            {"type": "boolean", "description": "Detect US SSNs."},
    "check_secrets_api_key":    {"type": "boolean", "description": "Detect common API key formats."},
    "check_secrets_private_key":{"type": "boolean", "description": "Detect PEM-encoded private keys."},
    "check_secrets_password":   {"type": "boolean", "description": "Detect inline password assignments."},
    "check_credit_card":        {"type": "boolean", "description": "Detect credit-card-like 16-digit sequences."},
    "check_ip_internal":        {"type": "boolean", "description": "Detect internal IPv4 addresses."},
    "custom_patterns": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Additional regular expressions; each match treated as a violation."
    }
  }
}
