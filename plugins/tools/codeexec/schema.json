{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/plugins/nexus.tool.code_exec.json",
  "title": "nexus.tool.code_exec",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "compiler":          {"type": "string", "enum": ["yaegi-host", "yaegi-wasm"]},
    "timeout_seconds":   {"type": "integer", "minimum": 1},
    "max_output_bytes":  {"type": "integer", "minimum": 0},
    "max_workers":       {"type": "integer", "minimum": 1},
    "persist_scripts":   {"type": "boolean"},
    "reject_goroutines": {"type": "boolean"},
    "allowed_packages":  {"type": "array", "items": {"type": "string"}},
    "blob_store": {
      "type": "object",
      "additionalProperties": false,
      "description": "Settings for the per-session blob store backing nexus.ReturnImage.",
      "properties": {
        "byte_budget":      {"type": "integer", "description": "Soft cap on total stored blob bytes per session. 0 = unbounded.", "default": 2147483648},
        "inline_threshold": {"type": "integer", "description": "Payloads at or below this size are inlined on the MessagePart instead of being stored as a blob.", "default": 262144}
      }
    },
    "sandbox": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "backend":      {"type": "string"},
        "cache_dir":    {"type": "string"},
        "timeout":      {"type": "string"},
        "net": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "policy":      {"type": "string", "enum": ["deny", "allow_hosts"]},
            "allow_hosts": {"type": "array", "items": {"type": "string"}}
          }
        },
        "fs_mounts":    {"type": "array"},
        "exec_allowed": {"type": "array", "items": {"type": "string"}},
        "env":          {"type": "object", "additionalProperties": {"type": "string"}}
      }
    }
  }
}
