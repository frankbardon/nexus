{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/plugins/nexus.tool.web.json",
  "title": "nexus.tool.web",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "search": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "count":       {"type": "integer", "minimum": 1, "description": "Default result count when the LLM omits one."},
        "safe_search": {"type": "string",  "enum": ["off", "moderate", "strict"], "description": "Default safe-search level."},
        "language":    {"type": "string",  "description": "Default search language code."}
      }
    },
    "fetch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "user_agent":       {"type": "string",  "description": "User-Agent header used for fetches."},
        "timeout":          {"type": "string",  "description": "Per-fetch timeout (Go duration)."},
        "max_size":         {"type": "string",  "description": "Maximum response size (e.g. 5MB)."},
        "extract_mode":     {"type": "string",  "enum": ["readability", "raw"], "description": "Default extraction mode for fetched bodies."},
        "allowed_domains":  {"type": "array",   "items": {"type": "string"}, "description": "Allow-list of fetchable domains."},
        "blocked_domains":  {"type": "array",   "items": {"type": "string"}, "description": "Deny-list of fetchable domains."},
        "follow_redirects": {"type": "boolean", "description": "Follow HTTP redirects."},
        "max_redirects":    {"type": "integer", "minimum": 0, "description": "Maximum redirect chain length."}
      }
    }
  }
}
