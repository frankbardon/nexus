{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/plugins/nexus.search.anthropic_native.json",
  "title": "nexus.search.anthropic_native",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "api_key":     {"type": "string", "description": "Direct Anthropic API key."},
    "api_key_env": {"type": "string", "description": "Environment variable holding the Anthropic API key."},
    "model":       {"type": "string", "description": "Model used to invoke the server-side web_search tool."},
    "timeout":     {"type": "string", "description": "HTTP timeout (Go duration)."}
  }
}
