{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/plugins/nexus.planner.static.json",
  "title": "nexus.planner.static",
  "type": "object",
  "additionalProperties": false,
  "required": ["steps"],
  "properties": {
    "approval": {"type": "string", "enum": ["always", "never", "auto"], "description": "Approval mode; auto and never are equivalent for static planner."},
    "summary":  {"type": "string", "description": "Human-readable label for the plan."},
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered execution steps.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description"],
        "properties": {
          "description":  {"type": "string", "description": "Short label for the step."},
          "instructions": {"type": "string", "description": "Detailed instructions injected when the step runs."}
        }
      }
    }
  }
}
