{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/plugins/nexus.rag.reranker.jina.json",
  "title": "nexus.rag.reranker.jina",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "api_key":     {"type": "string", "description": "Direct Jina API key."},
    "api_key_env": {"type": "string", "description": "Environment variable holding the Jina API key."},
    "model":       {"type": "string", "description": "Jina rerank model ID."},
    "timeout_ms":  {"type": "integer", "minimum": 1, "description": "HTTP timeout in milliseconds."},
    "api_base":    {"type": "string", "description": "Override Jina API base URL."}
  }
}
